{
  "_meta": {
    "description": "Centralized field mapping for ACS DP04 (Housing Characteristics) and DP05 (Demographic Estimates) profile tables.",
    "source": "U.S. Census Bureau — American Community Survey 5-Year Estimates",
    "tables": ["DP04", "DP05"],
    "updated": "2024"
  },
  "DP04": {
    "_description": "Selected Housing Characteristics",
    "DP04_0001E":  { "name": "total_housing_units",          "type": "integer",    "required": true,  "description": "Total housing units" },
