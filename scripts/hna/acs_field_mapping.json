    "DP04_0003E":  { "name": "vacant_housing_units",         "type": "integer",    "required": false, "description": "Vacant housing units" },
    "DP04_0003PE": { "name": "vacancy_rate",                 "type": "percentage", "required": false, "description": "Vacancy rate (%)", "range": [0, 100] },
    "DP04_0004E":  { "name": "homeowner_vacancy_rate_num",   "type": "float",      "required": false, "description": "Homeowner vacancy rate (numeric)" },
    "DP04_0005E":  { "name": "rental_vacancy_rate_num",      "type": "float",      "required": false, "description": "Rental vacancy rate (numeric)" },

    "DP04_0007E":  { "name": "units_1_detached",             "type": "integer",    "required": false, "description": "1-unit, detached structures" },
    "DP04_0008E":  { "name": "units_1_attached",             "type": "integer",    "required": false, "description": "1-unit, attached structures" },
    "DP04_0009E":  { "name": "units_2",                      "type": "integer",    "required": false, "description": "2-unit structures" },
    "DP04_0010E":  { "name": "units_3_4",                    "type": "integer",    "required": false, "description": "3-4 unit structures" },
