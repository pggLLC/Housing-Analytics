    "DP04_0089E":  { "name": "median_home_value",            "type": "integer",    "required": false, "description": "Median value of owner-occupied housing units ($)" },
    "DP04_0134E":  { "name": "median_gross_rent",            "type": "integer",    "required": false, "description": "Median gross rent ($)" },

    "DP04_0142PE": { "name": "grapi_lt15",                   "type": "percentage", "required": false, "description": "Gross rent as % of income: less than 15%", "range": [0, 100] },
    "DP04_0143PE": { "name": "grapi_15_19",                  "type": "percentage", "required": false, "description": "Gross rent as % of income: 15-19.9%", "range": [0, 100] },
