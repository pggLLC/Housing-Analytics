    "DP04_0046E":  { "name": "renter_occupied_units",        "type": "integer",    "required": false, "description": "Renter-occupied housing units" },
    "DP04_0046PE": { "name": "pct_renter_occupied",          "type": "percentage", "required": true,  "description": "% renter-occupied units", "range": [0, 100] },
    "DP04_0047E":  { "name": "owner_occupied_units",         "type": "integer",    "required": false, "description": "Owner-occupied housing units" },
