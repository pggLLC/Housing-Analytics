    "DP04_0012E":  { "name": "units_10_19",                  "type": "integer",    "required": false, "description": "10-19 unit structures" },
    "DP04_0013E":  { "name": "units_20_plus",                "type": "integer",    "required": false, "description": "20+ unit structures" },
    "DP04_0014E":  { "name": "units_mobile_home",            "type": "integer",    "required": false, "description": "Mobile homes" },

    "DP04_0011PE": { "name": "pct_units_5_9",                "type": "percentage", "required": false, "description": "% units in 5-9 unit structures", "range": [0, 100] },
    "DP04_0012PE": { "name": "pct_units_10_19",              "type": "percentage", "required": false, "description": "% units in 10-19 unit structures", "range": [0, 100] },
