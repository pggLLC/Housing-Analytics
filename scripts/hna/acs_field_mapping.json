    "DP04_0145PE": { "name": "grapi_25_29",                  "type": "percentage", "required": false, "description": "Gross rent as % of income: 25-29.9%", "range": [0, 100] },
    "DP04_0146PE": { "name": "grapi_30_34",                  "type": "percentage", "required": false, "description": "Gross rent as % of income: 30-34.9%", "range": [0, 100] },
    "DP04_0147PE": { "name": "grapi_35_plus",                "type": "percentage", "required": false, "description": "Gross rent as % of income: 35%+", "range": [0, 100] }
  },
