{
  "name": "lihtc-analytics-hub",
  "version": "2.0.0",
  "description": "Data-driven insights into LIHTC allocations, affordable housing development, and market dynamics across the United States.",
  "homepage": "https://github.com/your-org/lihtc-analytics-hub",
  "license": "MIT",
  "private": true,
  "scripts": {
    "serve": "npx serve . -p 3000",
    "validate": "node scripts/validate.js",
    "test:validate": "node test/validate-site.js",
    "test:fetch-helper": "node test/fetch-helper-resolve.js",
    "test:hna": "node test/hna-functionality-check.js",
    "test:pages": "node test/pages-availability-check.js",
    "test:contrast": "node scripts/contrast-audit/run.js",
    "lint:html": "npx htmlhint '*.html'",
    "lint:css": "npx stylelint 'css/*.css'",
    "audit:contrast": "node scripts/contrast-audit/run.js",
    "audit:data": "node scripts/audit/data-inventory.mjs",
    "audit:data:manifest": "node scripts/audit/data-inventory.mjs --json",
    "audit:site": "node scripts/audit/site-audit.mjs",
    "audit:install": "npx playwright install chromium --with-deps",
    "generate:car-placeholder": "node scripts/generate-car-placeholder.mjs",
    "validate:data": "node scripts/validate-critical-data.js",
    "monitor:report": "node scripts/monitoring/generate-report.js",
    "monitor:report:json": "node scripts/monitoring/generate-report.js --json",
    "monitor:check": "python3 scripts/monitoring/data-quality-check.py"
  },
  "dependencies": {
    "color": "^4.2.3",
    "glob": "^10.3.3",
    "jsdom": "^24.1.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.1",
    "playwright": "^1.58.2",
    "wcag-contrast": "^3.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "engines": {
    "node": ">=16"
  }
}
