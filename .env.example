# ============================================================
# Website Monitoring — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values for local testing.
# NEVER commit the .env file — it is listed in .gitignore.
# In CI/CD, set these as GitHub Secrets instead.
# ============================================================

# --- Required ---
EMAIL_USER=your_gmail_account@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
WEBSITE_URL=https://your-website-url.com
RECIPIENT_EMAIL=your_recipient_email@example.com

# --- Data API Keys ---
# FRED (Federal Reserve Economic Data) API key (https://fred.stlouisfed.org/docs/api/api_key.html)
# Used by scripts that pull mortgage rate and economic indicator data
FRED_API_KEY=your_fred_api_key

# U.S. Census Bureau API key (https://api.census.gov/data/key_signup.html)
# Used by fetch-census-acs workflow and scripts/hna/build_hna_data.py
# In CI/CD this is supplied via GitHub Secrets (CENSUS_API_KEY).
# For local development, set it here. Leave blank to use unauthenticated requests (rate-limited).
CENSUS_API_KEY=

# Kalshi prediction market API credentials (https://kalshi.com/docs/api)
# Used by scripts/kalshi/fetch_kalshi_prediction_markets.js and the fetch-kalshi workflow
KALSHI_API_KEY=your_kalshi_api_key
KALSHI_API_SECRET=your_kalshi_api_secret

# NOAA Climate Data Online (CDO) API token (https://www.ncdc.noaa.gov/cdo-web/token)
# Optional - used by DataService.fetchNOAAClimateData() in js/data-service-portable.js.
# Without this token the method returns a neutral stub (resilienceScore: 50).
NOAA_CDO_TOKEN=

# LODES/LEHD proxy URL
# Optional - used by DataService.fetchLODES() in js/data-service-portable.js.
# LODES bulk files cannot be queried spatially without a server-side proxy.
# Set to the URL of your deployed proxy to enable live commuting-flow data.
# Without this the method gracefully degrades to synthetic workplace distribution.
LODES_PROXY_URL=

# --- Front-end base path (GitHub Pages / custom domain) ---
# Optional - read by js/fetch-helper.js as window.APP_BASE_PATH.
# Set to the repository sub-path when hosting under a GitHub Pages project page
# (e.g. /Housing-Analytics/). Leave empty for a root-domain deployment.
APP_BASE_PATH=

# --- Request settings (optional) ---
# Timeout in milliseconds for each HTTP request (default: 10000)
MONITOR_TIMEOUT_MS=10000

# Maximum number of retries for transient failures (default: 3)
MONITOR_MAX_RETRIES=3

# Base delay in milliseconds between retries; doubles on each attempt (default: 1000)
MONITOR_RETRY_DELAY_MS=1000

# --- Performance settings (optional) ---
# Maximum number of concurrent link-check requests (default: 5)
MONITOR_CONCURRENCY=5

# Delay in milliseconds between requests in each worker (default: 200)
MONITOR_RATE_LIMIT_MS=200

# Response time threshold in milliseconds above which a link is flagged as slow (default: 2000)
MONITOR_SLOW_THRESHOLD_MS=2000

# --- Caching (optional) ---
# Enable result caching to avoid re-checking the same URL in a single run (default: true)
MONITOR_CACHE_ENABLED=true

# Time-to-live for cached results in milliseconds (default: 60000)
MONITOR_CACHE_TTL_MS=60000

# --- Debugging (optional) ---
# Enable verbose debug output (default: false)
MONITOR_DEBUG=false

# Perform a dry run: scan links and generate a report but do NOT send email (default: false)
MONITOR_DRY_RUN=false

# --- URL filtering (optional) ---
# Comma-separated list of URL substrings to skip during link checking
# Example: MONITOR_IGNORE_PATTERNS=mailto:,tel:,localhost
MONITOR_IGNORE_PATTERNS=
