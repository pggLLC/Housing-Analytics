# API key config with real secrets – never commit
js/config.local.js

# Environment variable files — may contain secrets
.env
.env.local
.env.*.local

# Python bytecode cache
__pycache__/
*.pyc

# Node.js dependencies
node_modules/

# Audit reports (generated locally; uploaded as CI artifacts)
audit-report/
monitoring-reports/

# macOS packaging artifacts
.DS_Store
__MACOSX/
._*

# Quarantine folders — moved here for review before permanent deletion
_tobedeleted/
_audit/

# GitHub Pages staging directory (created during deploy workflow)
_site/
.pytest_cache/
*.egg-info/
.venv/

# Claude Code local session state
.claude/

# Local build / fetch caches (e.g., CHAS, ACS download artifacts)
.cache/
