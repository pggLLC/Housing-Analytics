# API key config with real secrets – never commit
js/config.local.js

# Environment variable files — may contain secrets
.env
.env.local
.env.*.local

# Python bytecode cache
__pycache__/
*.pyc

# Node.js dependencies
node_modules/

# Audit reports (generated locally; uploaded as CI artifacts)
audit-report/
monitoring-reports/
accessibility-audit-results/

# macOS packaging artifacts
.DS_Store
__MACOSX/
._*

# Large regenerable raw data inputs — ~89MB Zillow ZHVI city CSV. The compact
# derived outputs (data/hna/home-value-cascade.json, zhvi-place-crosswalk.json)
# ARE committed; the raw CSV is re-downloadable for build_home_value_cascade.mjs.
data/zillow/*.csv

# Quarantine folders — moved here for review before permanent deletion
_tobedeleted/
_audit/

# GitHub Pages staging directory (created during deploy workflow)
_site/
dist/
.build-public-site.lock/
.pytest_cache/
*.egg-info/
.venv/

# Claude Code local session state
.claude/

# Local build / fetch caches (e.g., CHAS, ACS download artifacts)
.cache/

# Private/internal-only assets — must not ship to the public GitHub Pages site.
# The previous private/weekly-brief content was committed but not access-controlled
# (its own README admitted "It is not secured"); see SECURITY note in PR.
# Keep local copies if you need them; host them somewhere authenticated instead.
private/

# IDE save-as / duplicate artifacts (macOS Finder + some editors create
# "filename 2.ext" when re-saving; iCloud sync conflicts create "filename 3.ext",
# "filename 4.ext", etc. on subsequent conflicts. Keep common one-, two-, and
# three-digit suffix patterns aligned with scripts/audit/duplicate-artifact-scan.mjs.
*\ [0-9].*
*\ [0-9][0-9].*
*\ [0-9][0-9][0-9].*
*\ [0-9]/
*\ [0-9][0-9]/
*\ [0-9][0-9][0-9]/
data/hna/lodes-raw/
out/~$*
