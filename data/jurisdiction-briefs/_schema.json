{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Jurisdictional housing-history brief",
  "type": "object",
  "required": ["geoid", "jurisdiction", "scope", "containing_county_fips", "last_curated", "curator", "sections", "sources"],
  "properties": {
    "geoid": {
      "type": "string",
      "pattern": "^08[0-9]{3}([0-9]{2})?$",
      "description": "5-digit county FIPS or 7-digit place GEOID. Must match filename."
    },
    "jurisdiction": { "type": "string", "minLength": 3 },
    "scope": { "enum": ["place", "county", "cdp"] },
    "containing_county_fips": {
      "type": "string",
      "pattern": "^08[0-9]{3}$"
    },
    "last_curated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "curator": { "type": "string", "minLength": 2 },
    "summary": {
      "type": "string",
      "description": "Optional 1-2 sentence headline shown before the sections."
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Gate the brief from public-facing renders. Defaults to false — the brief stays internal until every paragraph is sourced (no needs_source flags) and a human has flipped this to true. The validator enforces: published=true implies zero needs_source paragraphs and zero kind=='search' sources."
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "heading", "paragraphs"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Slug. Sections starting with 'coalition-' or 'regional-' get looser cross-juris QA rules."
          },
          "heading": { "type": "string", "minLength": 3 },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text"],
              "properties": {
                "text": { "type": "string", "minLength": 10 },
                "cites": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Source ids from the sources array."
                },
                "needs_source": {
                  "type": "boolean",
                  "description": "True when the claim is unsourced; renderer surfaces a 'source pending' badge."
                }
              }
            }
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "url", "kind"],
        "properties": {
          "id": { "type": "string", "pattern": "^s[0-9]+$" },
          "label": { "type": "string", "minLength": 3 },
          "url": { "type": "string", "format": "uri" },
          "kind": { "enum": ["primary", "secondary", "press", "search"] },
          "accessed": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      }
    }
  }
}
